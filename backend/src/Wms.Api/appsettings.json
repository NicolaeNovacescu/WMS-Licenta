{
  "Application": {
    "Name": "WMS API"
  },
  "Auth": {
    "Jwt": {
      "Issuer": "Wms.Api",
      "Audience": "Wms.Frontend",
      "SigningKey": "development-signing-key-change-before-production",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 7
    }
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
